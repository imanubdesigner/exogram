# Django Core
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
ADMIN_URL=admin-CHANGE_THIS/  # ⚠️ Cambiar antes del primer deploy. También actualizar handle en Caddyfile.
FORCE_HTTPS=False
DJANGO_SETTINGS_MODULE=exogram.settings

# Database (choose one form)
POSTGRES_DB=exogram
POSTGRES_USER=exogram
POSTGRES_PASSWORD=dev_password
DB_HOST=db
DB_PORT=5432
# If set, DATABASE_URL overrides the explicit database form above.
DATABASE_URL=

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Postal — servidor SMTP self-hosted
POSTAL_DB_ROOT_PASSWORD=changeme_root
POSTAL_DB_PASSWORD=changeme_postal
# Generate con `openssl rand -hex 64` o equivalente.
POSTAL_RAILS_SECRET_KEY=replace_with_a_long_random_secret

# Auth / JWT / Cookies
JWT_ACCESS_TOKEN_MINUTES=20
JWT_REFRESH_TOKEN_DAYS=7
JWT_ACCESS_COOKIE_NAME=exo_access
JWT_REFRESH_COOKIE_NAME=exo_refresh
JWT_ACCESS_COOKIE_PATH=/api/
JWT_REFRESH_COOKIE_PATH=/api/auth/
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_DOMAIN=

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_BASE_URL=http://localhost:5173

# Email (Postal SMTP)
EMAIL_HOST=postal
EMAIL_PORT=587
# Estas credenciales se generan dentro de Postal para el server SMTP.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@tudominio.com

# Password Reset
PASSWORD_RESET_TOKEN_TTL_HOURS=2  # optional

# Monitoring
SENTRY_DSN=  # optional

# Caddy / Compose (root .env only)
APP_DOMAIN=example.com
ACME_EMAIL=ops@example.com

# Frontend Build
VITE_API_URL=https://example.com  # Required at build time. Alternatively, refactor frontend to use a relative API base.
VITE_DONATION_ALIAS=tu.alias.banco  # Optional. If set, shows donation tags across the app.

# GitHub Actions Deploy
# These are GitHub Actions secrets, not runtime env vars.
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_SSH_KEY=
DEPLOY_PATH=/opt/exogram

# Not currently used — do not configure
GOOGLE_CLIENT_ID=  # NOT CURRENTLY USED — no code references this value
GOOGLE_CLIENT_SECRET=  # NOT CURRENTLY USED — no code references this value
GOOGLE_CALLBACK_URL=  # NOT CURRENTLY USED — no code references this value
GITHUB_CLIENT_ID=  # NOT CURRENTLY USED — no code references this value
GITHUB_CLIENT_SECRET=  # NOT CURRENTLY USED — no code references this value
GITHUB_CALLBACK_URL=  # NOT CURRENTLY USED — no code references this value
EMBEDDING_MODEL=  # NOT CURRENTLY USED — no code references this value
