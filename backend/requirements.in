# requirements.in — fuente de verdad para pip-compile.
#
# Para regenerar requirements.txt con versiones y hashes exactos:
#
#   pip install pip-tools
#   pip-compile requirements.in --generate-hashes -o requirements.txt
#
# Para actualizar una dependencia específica:
#
#   pip-compile requirements.in --upgrade-package Django -o requirements.txt
#
# Para verificar que requirements.txt está sincronizado con este archivo:
#
#   pip-compile --dry-run requirements.in

